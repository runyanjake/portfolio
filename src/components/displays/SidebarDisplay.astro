---
import type { IndexItem } from '../../layouts/IndexLayout.astro';
import SidebarNav from '../SidebarNav.astro';

interface Props {
  items: IndexItem[];
  currentUrl?: string;
}

const { items, currentUrl } = Astro.props;
---

<div class="display-sidebar">
  <aside class="display-sidebar__nav" aria-label="Section navigation">
    <SidebarNav items={items} currentUrl={currentUrl} />
  </aside>
  <div class="display-sidebar__main">
    <slot />
  </div>
</div>
